{
  "name": "@owf/mdoc",
  "description": "ISO 18013-5 Mdoc and MDL",
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.8.0",
  "author": "Animo Solutions",
  "exports": "./src/index.ts",
  "version": "0.7.0",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
      ".": "./dist/index.mjs",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "types:check": "tsc --noEmit",
    "style:check": "biome check --unsafe",
    "style:fix": "biome check --write --unsafe",
    "build": "tsdown",
    "test": "vitest",
    "release": "pnpm build && pnpm changeset publish --no-git-tag",
    "changeset-version": "pnpm changeset version && pnpm style:fix"
  },
  "engines": {
    "node": ">=20.19"
  },
  "dependencies": {
    "@owf/cose": "^0.3.0",
    "@owf/identity-common": "^0.3.0",
    "@owf/token-status-list": "^0.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@changesets/cli": "^2.30.0",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@panva/hkdf": "^1.2.1",
    "@peculiar/x509": "^2.0.0",
    "@types/node": "^25.5.0",
    "jose": "^6.2.2",
    "nock": "^14.0.15",
    "reflect-metadata": "^0.2.2",
    "tsdown": "^0.22.2",
    "typescript": "~6.0.3",
    "vitest": "^4.1.8"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/openwallet-foundation-labs/mdoc-ts"
  },
  "keywords": [
    "mdl",
    "iso-18013-5",
    "iso-18013-7",
    "m-doc",
    "m-doc-cbor",
    "m-doc-cbor-parser",
    "m-doc-cbor-validator",
    "m-doc-cbor-encoder",
    "m-doc-cbor-decoder",
    "m-doc-cbor-iso-18013-5",
    "m-doc-cbor-iso-18013-5-parser",
    "m-doc-cbor-iso-18013-5-validator",
    "m-doc-cbor-iso-18013-5-encoder",
    "m-doc-cbor-iso-18013-5-decoder"
  ]
}
